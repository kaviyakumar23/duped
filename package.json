{
  "name": "duped",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:check": "tsx --env-file-if-exists=.env.local scripts/check-db.ts",
    "db:migrate": "tsx --env-file-if-exists=.env.local scripts/migrate.ts",
    "db:index-status": "tsx --env-file-if-exists=.env.local scripts/index-status.ts",
    "db:setup-ddb": "tsx --env-file-if-exists=.env.local scripts/setup-ddb.ts",
    "db:seed": "tsx --env-file-if-exists=.env.local scripts/seed.ts",
    "db:reset-ddb": "tsx --env-file-if-exists=.env.local scripts/reset-ddb.ts",
    "projector": "tsx --env-file-if-exists=.env.local scripts/projector.ts",
    "storm": "tsx --env-file-if-exists=.env.local scripts/swarm.ts",
    "swarm": "tsx --env-file-if-exists=.env.local scripts/swarm.ts",
    "reconcile": "tsx --env-file-if-exists=.env.local scripts/reconcile.ts",
    "prove": "tsx --env-file-if-exists=.env.local scripts/prove.ts",
    "demo:reset": "pnpm db:seed && pnpm db:reset-ddb",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/credential-providers": "^3.700.0",
    "@aws-sdk/dsql-signer": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@aws/aurora-dsql-node-postgres-connector": "^0.1.9",
    "@vercel/functions": "^3.7.3",
    "drizzle-orm": "^0.45.2",
    "geist": "^1.3.1",
    "next": "^15.1.6",
    "p-limit": "^6.1.0",
    "pg": "^8.13.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
